{
    "height": 30,
    "layer": "top",
    "modules-left": ["custom/launcher", "hyprland/workspaces", "custom/spotify"],
    "modules-center": ["clock"],
    "modules-right": [
        "cpu",
        "memory",
        "custom/theme",
        "custom/wallpaper",
        "network",
        "pulseaudio",
        
        "custom/power-menu"
    ],
    "hyprland/workspaces": {
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate",
        "format": "{icon}",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "format-icons": {
            "1": "¾░«»",
            "2": "´ë®",
            "3": "¾░¿Ş",
            "4": "´äô",
            "5": "´å╝",
            "6": "´ôö",
            "urgent": "´ü¬",
            "default": "´äæ"
        },
        "persistent-workspaces": {
            "*": 6
        }
    },
    "clock": {
        "interval": 60,
        "align": 0,
        "rotate": 0,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%d %b, %H:%M %p}",
        "format-alt": "{:%a %b %d, %G} "
    },
    "cpu": {
        "interval": 10,
        "format": "´Æ╝ {}%",
        "max-length": 10,
        "on-click": "kitty btm"
    },
    "memory": {
        "interval": 30,
        "format": "´êÇ {}%",
        "format-alt": "´êÇ {used:0.1f}GB",
        "max-length": 10
    },
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "¾░ó¥",
        "format-disconnected": "¾░¬Ä",
        "tooltip-format": "{essid}",
        "on-click": "kitty nmtui",
        "format-icons": ["¾░ñ»", "¾░ñş", "¾░ñó", "¾░ñÑ", "¾░ñ¿"]
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "¾░ûü",
        "format-icons": {
            "default": ["´ÇĞ", "´Çğ", "¾░ò¥"]
        },
        "on-click": "pavucontrol &",
        "on-click-right": "pamixer -t",
        "scroll-step": 5,
        "on-scroll-up": "~/.config/waybar/scripts/volume.sh --inc",
        "on-scroll-down": "~/.config/waybar/scripts/volume.sh --dec"
    },
    "custom/spotify": {
        "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py --player spotify",
        "format": "´å╝ {}",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "max-length": 50
    },
    "custom/power-menu": {
        "format": " ´Çæ ",
        "on-click": "~/.config/rofi/scripts/powermenu"
    },
    "custom/launcher": {
        "format": "´îâ",
        "on-click": "~/.config/rofi/scripts/launcher"
    },
    "custom/wallpaper": {
        "format": "¾░ï╣",
        "on-click": "~/.config/rofi/scripts/wallpaper",
        "on-click-right": "~/.config/waybar/scripts/wallpaper.sh"
    },
    "custom/theme": {
        "format": "¾░èá",
        "on-click": "~/.config/waybar/scripts/theme.sh"
    }
}
