{
  "height": 30,
  "layer": "top",
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "custom/chatai",
    "custom/spotify"
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/weather",
    "temperature",
    "cpu",
    "memory",
    "custom/pacman",
    "custom/theme",
    "custom/wallpaper",
    "network",
    "pulseaudio",
    "custom/power-menu"
  ],

  "custom/launcher": {
    "format": "’īā",
    "on-click": "~/.config/rofi/scripts/launcher"
  },

  "hyprland/workspaces": {
    "all-outputs": true,
    "active-only": false,
    "on-click": "activate",
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "1": "¾░«»",
      "2": "’ē®",
      "3": "¾░©×",
      "4": "’äō",
      "5": "’å╝",
      "6": "’ü╝",
      "urgent": "’ü¬",
      "default": "’äæ"
    },
    "persistent-workspaces": {
      "*": 6
    }
  },

  "custom/spotify": {
    "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py --player spotify",
    "format": "’å╝ {}",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "max-length": 50
  },

  "clock": {
    "interval": 60,
    "align": 0,
    "rotate": 0,
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:’ä│  %d %b %Y | ’É║  %H:%M %p}",
    "format-alt": "{:’ä│  %d de %b, %A | %G} "
  },

  "custom/weather": {
    "format": "¾▒Ż¢ {}",
    "exec": "~/.config/waybar/scripts/weather.sh Tiangua",
    "return-type": "json",
    "interval": 600
  },

  "temperature": {
    "thermal-zone": 2,
    "hwmon-path": [
      "/sys/class/hwmon/hwmon2/temp1_input",
      "/sys/class/thermal/thermal_zone0/temp"
    ],
    "critical-threshold": 80,
    "format-critical": "¾▒ŚŚ {temperatureC}┬░C",
    "format": "¾░Äō {temperatureC}┬░C"
  },

  "cpu": {
    "interval": 10,
    "format": "’Æ╝ {}%",
    "max-length": 10,
    "on-click": "kitty btm"
  },

  "memory": {
    "interval": 30,
    "format": "’æ▓ {}%",
    "format-alt": "’æ▓ {used:0.1f}GB",
    "max-length": 10
  },

  "custom/pacman": {
    "format": "{icon} {}",
    "return-type": "json",
    "format-icons": {
      "pending-updates": "’ĆÖ",
      "updated": "’üØ "
    },
    "exec-if": "which waybar-updates",
    "exec": "waybar-updates",
    "on-click": "kitty yay -Syu --noconfirm"
  },

  "custom/theme": {
    "format": "¾░ŖĀ",
    "on-click": "~/.config/waybar/scripts/theme.sh"
  },

  "custom/wallpaper": {
    "format": "¾░ŗ╣",
    "on-click": "~/.config/rofi/scripts/wallpaper",
    "on-click-right": "~/.config/waybar/scripts/wallpaper.sh"
  },

  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "¾░¢¤",
    "format-disconnected": "¾░¬Ä",
    "tooltip-format": "{essid}",
    "on-click": "kitty nmtui",
    "format-icons": ["¾░ż»", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"]
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "¾░¢ü",
    "format-icons": {
      "default": ["’Ć”", "’Ć¦", "¾░ĢŠ"]
    },
    "on-click": "pavucontrol &",
    "on-click-right": "pamixer -t",
    "scroll-step": 5,
    "on-scroll-up": "~/.config/waybar/scripts/volume.sh --inc",
    "on-scroll-down": "~/.config/waybar/scripts/volume.sh --dec"
  },

  "custom/power-menu": {
    "format": " ’Ćæ ",
    "on-click": "~/.config/rofi/scripts/powermenu"
  }
}
