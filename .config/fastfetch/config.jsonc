{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "packages",
    "shell",
    {
        "type": "display",
        "format": "{name} {width}x{height} {refresh-rate}Hz {inch}\""
    },
    "de",
    "wm",
    "terminal",
    "cpu",
    "gpu",
    "disk",
    "memory",
    "swap",
    "uptime",
    "break",
    "colors"
  ]
}
